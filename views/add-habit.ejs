<%- include('partials/header') %>

<section id="add-habit">
    <%- include('partials/session') %>
    <h2>Добавить новую привычку</h2>
    <img src="/img/1.jpg" alt="Рандом фото 1">
    <article>
        <h3>Форма добавления</h3>
        <form action="#" method="post">
            <p>
                <label for="habit-name"><strong>Название:</strong></label><br>
                <input type="text" id="habit-name" name="habit-name" placeholder="Утренняя зарядка">
            </p>
            <p>
                <label for="habit-time"><b>Время:</b></label><br>
                <input type="time" id="habit-time" name="habit-time" value="07:00">
            </p>
            <p><em>Дни недели:</em></p>
            <div class="flex-row">
                <input type="checkbox" id="day-mon" name="day-mon" checked>
                <label for="day-mon">Пн</label>

                <input type="checkbox" id="day-tue" name="day-tue" checked>
                <label for="day-tue">Вт</label>

                <input type="checkbox" id="day-wed" name="day-wed" checked>
                <label for="day-wed">Ср</label>

                <input type="checkbox" id="day-thu" name="day-thu" checked>
                <label for="day-thu">Чт</label>

                <input type="checkbox" id="day-fri" name="day-fri" checked>
                <label for="day-fri">Пт</label>
            </div>
            <button type="submit">Создать привычку</button>
        </form>
    </article>

    <aside>
        <h4>Совет</h4>
        <p>Начинайте с <i>маленьких привычек</i> по 5–10 минут в день</p>
    </aside>
</section>

<%- include('partials/footer') %>
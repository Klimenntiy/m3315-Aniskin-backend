cat > .gitignore << 'EOF'
# Зависимости
node_modules/

# Сборка
dist/

# Логи
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
/shelf/
/workspace.xml
/httpRequests/
/dataSources/
/dataSources.local.xml

# Системные файлы
.DS_Store
Thumbs.db

# env файлы
.env
.env.local
.env.*.local

# Временные файлы
tmp/
temp/
EOF